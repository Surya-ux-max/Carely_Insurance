# GigShield AI - Backend Configuration

# App Settings
APP_NAME=GigShield AI
DEBUG=True
VERSION=0.1.0

# Database (Local PostgreSQL)
# Make sure PostgreSQL is running locally before starting the app
# Default connection assumes PostgreSQL on localhost:5432
DATABASE_URL=postgresql://postgres:password@localhost:5432/gigshield_db

# Redis (Optional - for caching)
# Leave as-is if not using Redis, or set to empty string
REDIS_URL=redis://localhost:6379/0

# API Keys (Optional - for future integrations)
OPENWEATHER_API_KEY=your_api_key_here
RAZORPAY_KEY_ID=your_key_id_here
RAZORPAY_KEY_SECRET=your_key_secret_here

# ML Model Settings
DISRUPTION_THRESHOLD=0.65
FRAUD_DETECTION_THRESHOLD=0.75

# Payment Settings
DEFAULT_PAYOUT_AMOUNT=200.0

# Data Source Settings
WEATHER_CHECK_INTERVAL_MINUTES=60
DELIVERY_DATA_CHECK_INTERVAL_MINUTES=30
